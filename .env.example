# Copy to .env for local development (never commit .env).

# Required in production — generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Local: True | Production (PythonAnywhere): False
DJANGO_DEBUG=True

# Comma-separated, no spaces. Example: myuser.pythonanywhere.com
ALLOWED_HOSTS=127.0.0.1,localhost

# When using HTTPS (PythonAnywhere). Example: https://myuser.pythonanywhere.com
# CSRF_TRUSTED_ORIGINS=https://myuser.pythonanywhere.com
